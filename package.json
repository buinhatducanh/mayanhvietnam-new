{
  "name": "mayanhvietnam-new",
  "version": "1.0.0",
  "private": true,
  "description": "Rebuild website mayanhvietnam.com - Monorepo",
  "scripts": {
    "dev:web": "pnpm --filter web-public-next dev",
    "dev:admin": "pnpm --filter admin-next dev",
    "dev:api": "pnpm --filter api dev",
    "build:web": "pnpm --filter web-public-next build",
    "build:admin": "pnpm --filter admin-next build",
    "build:api": "pnpm --filter api build",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:studio": "pnpm --filter api prisma:studio",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
