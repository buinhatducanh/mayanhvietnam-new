{
  "name": "mayanhvietnam-new",
  "version": "1.0.0",
  "private": true,
  "description": "Rebuild website mayanhvietnam.com - Monorepo gồm 10 demo FE projects + admin + API",
  "scripts": {
    "dev:admin-next": "pnpm --filter admin-next dev",
    "build:admin-next": "pnpm --filter admin-next build",
    "dev:api": "pnpm --filter api dev",
    "build:api": "pnpm --filter api build",
    "dev:demo-01": "pnpm --filter demo-01 dev",
    "build:demo-01": "pnpm --filter demo-01 build",
    "dev:demo-02": "pnpm --filter demo-02 dev",
    "build:demo-02": "pnpm --filter demo-02 build",
    "dev:demo-03": "pnpm --filter demo-03 dev",
    "build:demo-03": "pnpm --filter demo-03 build",
    "dev:demo-04": "pnpm --filter demo-04 dev",
    "build:demo-04": "pnpm --filter demo-04 build",
    "dev:demo-05": "pnpm --filter demo-05 dev",
    "build:demo-05": "pnpm --filter demo-05 build",
    "dev:demo-06": "pnpm --filter demo-06 dev",
    "build:demo-06": "pnpm --filter demo-06 build",
    "dev:demo-07": "pnpm --filter demo-07 dev",
    "build:demo-07": "pnpm --filter demo-07 build",
    "dev:demo-08": "pnpm --filter demo-08 dev",
    "build:demo-08": "pnpm --filter demo-08 build",
    "dev:demo-09": "pnpm --filter demo-09 dev",
    "build:demo-09": "pnpm --filter demo-09 build",
    "dev:demo-10": "pnpm --filter demo-10 dev",
    "build:demo-10": "pnpm --filter demo-10 build",
    "dev:demo-shell": "pnpm --filter demo-shell dev",
    "build:demo-shell": "pnpm --filter demo-shell build",
    "dev:all": "pnpm --filter admin-next dev & pnpm --filter api dev & pnpm --filter demo-01 dev & pnpm --filter demo-02 dev & pnpm --filter demo-03 dev & pnpm --filter demo-04 dev & pnpm --filter demo-05 dev & pnpm --filter demo-06 dev & pnpm --filter demo-07 dev & pnpm --filter demo-08 dev & pnpm --filter demo-09 dev & pnpm --filter demo-10 dev & pnpm --filter demo-shell dev",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:studio": "pnpm --filter api prisma:studio",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
